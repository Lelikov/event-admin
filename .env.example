# event-admin configuration template. Copy to .env and fill in real values.
# Outside DEBUG=True the service refuses to start with secrets shorter than
# 16 characters or known placeholder values.

POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5439/zhivaya-admin

# NEVER set DEBUG=True in production. It does NOT bypass authentication
# (auth is always enforced), but it relaxes secret-strength validation
# and switches log rendering to console mode.
DEBUG=False
LOG_LEVEL=INFO

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
# Optional aud/iss binding (must match event-users' JWT_AUDIENCE/JWT_ISSUER):
# JWT_AUDIENCE=event-admin-api
# JWT_ISSUER=event-admin

CORS_ORIGINS=["http://localhost:5173"]

USERS_SERVICE_URL=http://127.0.0.1:8883
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
USERS_SERVICE_API_TOKEN=
CACHE_INVALIDATION_TOKEN=
USERS_CACHE_TTL_SECONDS=300

# Static bearer token for GET /api/blacklist/active (service endpoint used by
# event-booking; compared with hmac.compare_digest). Must match event-booking's
# BLACKLIST_SERVICE_TOKEN.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
BLACKLIST_SERVICE_TOKEN=

EVENT_RECEIVER_URL=http://127.0.0.1:8000
# Must match ADMIN_API_KEY in event-receiver. Sent as the raw Authorization
# header value (event-receiver compares it with hmac.compare_digest).
EVENT_RECEIVER_API_KEY=

# Login throttling (per client-IP + email, in-memory)
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_SECONDS=300

# Event publish retry/timeout (httpx -> event-receiver)
EVENT_PUBLISH_ATTEMPTS=3
EVENT_PUBLISH_TIMEOUT_SECONDS=10
